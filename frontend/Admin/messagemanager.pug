doctype html
head
  meta(charset='utf-8')
  title Admin panel
  style
    include ./css/textstyle.css
.pb-2.mt-4.mb-2.border-bottom.header
  | AARHUSTECH
.container_msg
  .center
    h2#msgtitle Post message
    form(action='/postnews' method="post")
      p#ttitle(for='fname')
        | Title: 
        textarea#title(type='text', name='title')
        br
        br
        label#tmessage(for='lname') Message:
        textarea#msg(type='text', name='msg' maxlength="200")
        br
        br
        input#postmsg(type='submit', value='post message')
        input#editmsg(type='submit', value='edit message')
        input#delmsg(type='submit', value='delete message')
        #savedmsg.container_savedmsg
      .startbox
        label(for='start') Start dato:
        input#startdato(type='date', name='msg_startdato', pattern='\d{4}-\d{2}-\d{2}')
        label.endbox(for='end') Slut dato:
        input#enddato(type='date', name='msg_enddato', pattern='\d{4}-\d{2}-\d{2}')
