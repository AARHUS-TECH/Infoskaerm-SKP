doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Admin panel
    // fontawesome cdn
    link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.1/css/all.min.css' integrity='sha512-+4zCK9k+qNFUR5X+cKL9EIR+ZOhtIloNl9GIKS57V1MyNsYpYcUrUeQc9vNfzsWfV28IaLL3i96P9sdNyeRssA==' crossorigin='anonymous')
    // my css
    style
      include ./css/style.css
  body
    nav#nav.navbar
      .nav-items
        .admin-profile
          .icons
            a(href='index.pug')
              img(src='user.png' alt='admin')
          span
            a(href='index.pug') Admin
        .item-list
          .icons
            a(href='dashboard.pug')
              i.fas.fa-tachometer-alt
          span
            a(href='dashboard.pug') Dashboard
        .item-list
          .icons
            a(href='database.pug')
              i.fas.fa-wallet
          span
            a(href='database.pug') Database
        .logout
          .icons
            a(href='logout.pug')
              i.fas.fa-sign-out-alt
          span
            a(href='logout.pug') Logout
    // javascript
    script(src='main.js')
    html
      head
        link(rel='stylesheet' href='nstatus.css')
      #box.gradient-border
        p#nstatus netværkstatus
    link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.1/css/all.min.css' integrity='sha512-+4zCK9k+qNFUR5X+cKL9EIR+ZOhtIloNl9GIKS57V1MyNsYpYcUrUeQc9vNfzsWfV28IaLL3i96P9sdNyeRssA==' crossorigin='anonymous')
    // css
    html
      body(onload='loadDoc()')
        #msgman
        script.
          function loadDoc() {
          const xhttp = new XMLHttpRequest();
          xhttp.onload = function() {
          document.getElementById("msgman").innerHTML =
          this.responseText;
          }
          xhttp.open("GET", "messagemanager.pug");
          xhttp.send();
          }
