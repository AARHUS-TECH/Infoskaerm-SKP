doctype html
head
  meta(charset='UTF-8')
  meta(http-equiv='X-UA-Compatible', content='IE=edge')
  meta(name='viewport', content='width=device-width, initial-scale=1.0')
  title Document
  link(rel='stylesheet', href='https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css')
style.
  .card{
  background-color: grey;
  border: none !important;
  }
  .card.body {
  background-color: rgb(0, 0, 0);
  opacity: .8;
  }
  html {
  background-color: grey;
  }
  .row{
  background-color: white;
  border-radius: 10px;
  }
  #box{
  max-width: 600px;
  margin-top: 10%;
  }
  #password{
  min-width: 550px;
  }
  #username{
  min-width: 550px;
  }
  h3{
  min-width: 550px;
  }
.card
  .card-body.text-black.bg-white.align-items-center
    img.mx-auto.d-block(src='download-1-removebg-preview.png', width='100px', height='100px', alt='aarhustech logo')
  // top af skærmen med logo
  #box.container
    .row
      .col-sm-6.content
        h3#login .login-mb-3.text-center login
        // grid system
        form
          .form-group
            // username
            label ID
            input#username.form-control(type='username', name='id')
          .form-group
            // password
            label Password
            input#password.form-control(type='password', name='password')
          .form-group.form-check
            // -check box
            input#remember.form-check-input(type='checkbox', name='checkbox')
            label.form-check-label Remember me 
          button.btn.btn-class.border.border-dark login
    script(src='https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js')
    script(src='https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.16.0/umd/popper.min.js')
    script(src='https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js')
